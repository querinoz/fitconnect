{
  "name": "fitconnect",
  "version": "1.0.0",
  "private": true,
  "description": "FitConnect — Marketplace connecting athletes with specialised personal trainers",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "smoke": "node scripts/smoke-test.mjs http://localhost:3001",
    "smoke:mobile": "node scripts/mobile-pwa-check.mjs http://localhost:3001",
    "smoke:all": "npm run smoke && npm run smoke:mobile",
    "env:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/make-start.ps1",
    "env:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/make-stop.ps1",
    "env:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/make-clean.ps1",
    "env:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/make-status.ps1"
  },
  "dependencies": {
    "next": "^14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4",
    "class-variance-authority": "^0.7.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "recharts": "^2.13.3",
    "zustand": "^5.0.1",
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "tailwindcss": "^3.4.14",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18"
  }
}
